# Runtime

NODE_ENV=

PORT=



# JWT used to sign auth tokens

JWT_SECRET=

# Optional token lifetime

JWT_EXPIRES_IN=



# CORS allowlist (comma-separated origins, no trailing slashes)

CORS_ORIGINS=



# Upload limit in MB

MAX_UPLOAD_MB=



# Groq API key (optional if using fallback mode)

GROQ_API_KEY=



# Optional Groq model override

GROQ_MODEL=



# Supabase (PostgreSQL) connection

# Prefer using the service role key for server-side writes.

SUPABASE_URL=

SUPABASE_SERVICE_ROLE_KEY=

# Optional: use anon key only if you enabled appropriate Row Level Security policies.

SUPABASE_ANON_KEY=

