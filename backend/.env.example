# Runtime

NODE_ENV=production

PORT=5000



# CORS allowlist (comma-separated origins)

CORS_ORIGINS=https://your-frontend.example.com



# Upload limit in MB

MAX_UPLOAD_MB=8



# Groq API key (optional if using fallback mode)

GROQ_API_KEY=your_key_here



# Optional Groq model override

GROQ_MODEL=llama-3.3-70b-versatile



# Supabase (PostgreSQL) connection

# Prefer using the service role key for server-side writes.

SUPABASE_URL=https://your-project-ref.supabase.co

SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Optional: use anon key only if you enabled appropriate Row Level Security policies.

SUPABASE_ANON_KEY=your_anon_key_here

